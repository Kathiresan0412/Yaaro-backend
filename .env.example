# NODE_ENV=development
# PORT=8000
# DATABASE_URL="postgresql://user:password@localhost:5432/yaaroo?sslmode=disable"
# DATABASE_POOL_MAX=1
# JWT_SECRET="change-me-local"
# ADMIN_JWT_SECRET="change-me-admin-only-local"
# REDIS_URL="redis://localhost:6379"
# CDN_URL="http://localhost:8000"

# ADMIN_EMAIL="admin@example.com"
# ADMIN_PHONE="+10000000000"
# ADMIN_PASSWORD="change-me-admin-password"

# CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
# CLOUDINARY_API_KEY="your-cloudinary-api-key"
# CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="smtp-user@example.com"
# SMTP_PASSWORD="your-smtp-password"
# MAIL_FROM="no-reply@example.com"
# SMTP_FROM_NAME="Primozen Solutions"
# PUBLIC_WEB_URL="http://localhost:3000"

# SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
# SPOTIFY_CLIENT_ID="your-spotify-client-id"

# Stripe mode: "sandbox" (default) uses test keys, "production" uses live keys.
# STRIPE_MODE=sandbox

# Stripe Sandbox (test) keys — use during development and testing
# STRIPE_PUBLISHABLE_KEY_SANDBOX="pk_test_..."
# STRIPE_SECRET_KEY_SANDBOX="sk_test_..."
# STRIPE_WEBHOOK_SECRET_SANDBOX="whsec_test_..."
# Optional: price IDs from your Stripe test dashboard (leave empty to use DB plan prices)
# STRIPE_PRICE_PLUS_SANDBOX="price_test_..."
# STRIPE_PRICE_GOLD_SANDBOX="price_test_..."
# STRIPE_PRICE_PLATINUM_SANDBOX="price_test_..."

# Stripe Production (live) keys — only active when STRIPE_MODE=production
# STRIPE_PUBLISHABLE_KEY_PRODUCTION="pk_live_..."
# STRIPE_SECRET_KEY_PRODUCTION="sk_live_..."
# STRIPE_WEBHOOK_SECRET_PRODUCTION="whsec_live_..."
# STRIPE_PRICE_PLUS_PRODUCTION="price_live_..."
# STRIPE_PRICE_GOLD_PRODUCTION="price_live_..."
# STRIPE_PRICE_PLATINUM_PRODUCTION="price_live_..."

# Legacy fallback keys (used if the _SANDBOX / _PRODUCTION variants are not set)
# STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
# STRIPE_SECRET_KEY="your-stripe-secret-key"
# STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
# STRIPE_PRICE_PLUS="your-stripe-plus-price-id"
# STRIPE_PRICE_GOLD="your-stripe-gold-price-id"
# STRIPE_PRICE_PLATINUM="your-stripe-platinum-price-id"

# SENDGRID_API_KEY="your-sendgrid-api-key"
# SENDGRID_FROM_EMAIL="Yaro0"
# VAPID_PUBLIC_KEY="your-web-push-public-key"
# VAPID_PRIVATE_KEY="your-web-push-private-key"
# VAPID_SUBJECT="mailto:admin@yaro0.com"

# TikTok OAuth Credentials
# TIKTOK_CLIENT_KEY="your-tiktok-client-key"
# TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"
